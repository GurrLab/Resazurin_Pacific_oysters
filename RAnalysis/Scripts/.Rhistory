dplyr::filter(Well %in% loop.df_i[i,1]) %>%
dplyr::arrange(time) %>%
dplyr::mutate(hours = as.numeric(difftime(time,
time[1],
units = "hours")),
delta_florescence = flourescence - flourescence[1],
AUC = pracma::trapz(
hours,
flourescence)) %>%
dplyr::select('Date', 'Treatment', 'PlateID', 'Age', 'time', 'Family', 'hours',
