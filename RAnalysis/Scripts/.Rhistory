output.cumulative.df <- data.frame() # start dataframe
output.df            <- data.frame() # start dataframe
output.cor.df        <- data.frame() # start dataframe
running.df           <- data.frame(matrix(nrow = 1, ncol = 9)) # create dataframe to save cumunalitively during for loop
colnames(running.df) <- c('Date', 'Treatment', 'PlateID', 'Age', 'Well', 'Family', 'Type', 'Count', 'AUC') # names for columns in the for loop
for(m in 1:nrow(loop.df_m)){
plate_id      <- all_data_merged %>%
dplyr::filter(PlateID %in% loop.df_m[m,1])
for(i in 1:nrow(loop.df_i)){
well.over.time       <- plate_id %>%
dplyr::filter(Well %in% loop.df_i[i,1]) %>%
dplyr::arrange(time) %>%
dplyr::mutate(hours = as.numeric(difftime(time,
time[1],
units = "hours")),
delta_florescence = flourescence - flourescence[1],
AUC = pracma::trapz(
hours,
flourescence)) %>%
dplyr::select('Date', 'Treatment', 'PlateID', 'Age', 'time', 'Family', 'hours',
'Well', 'Type', 'Count', 'AUC', 'delta_florescence')
output.cumulative.df <- rbind(output.cumulative.df, well.over.time)
running.df$Date      <- well.over.time$Date[1]
running.df$Treatment <- well.over.time$Treatment[1]
running.df$PlateID   <- well.over.time$PlateID[1]
running.df$Age       <- well.over.time$Age[1]
running.df$Well      <- well.over.time$Well[1]
running.df$Family    <- well.over.time$Family[1]
running.df$Type      <- well.over.time$Type[1]
running.df$Count     <- well.over.time$Count[1]
running.df$AUC       <- well.over.time$AUC[1]
output.df <- rbind(output.df,
running.df) #bind to a cumulative list dataframe
print(output.df) # print to monitor progress
mean.AUC.blanks <- mean(
(output.df %>% dplyr::filter(Type %in% 'Blank'))$AUC
)
output.cor.df <- output.df %>%
dplyr::filter(!Type %in% 'Blank') %>%
dplyr::mutate(AUC_cor      = as.numeric(AUC-mean.AUC.blanks),
# AUC_cor_norm = AUC_cor/Count)
AUC_cor_norm = dplyr::case_when(
(AUC_cor < 0 | Count == 0) ~ NA,
(AUC_cor > 0 & Count >= 10) ~ AUC_cor/Count)) %>%
na.omit()
}
}
output.cor.df_final <- merge(plate_notes, output.cor.df) %>%
dplyr::mutate(Family_EBV =
dplyr::case_when(Family > 50 ~ 'Low',
Family < 20 ~ 'High'))
output.cumulative.df <- merge(plate_notes, output.cumulative.df) %>% dplyr::mutate(Family_EBV =
dplyr::case_when(Family > 50 ~ 'Low',
Family < 20 ~ 'High'))
output.cor.df_final_omit <- output.cor.df_final %>%
dplyr::filter(!obs_volume %in% 'has no volume') #%>%
output.cumulative.df_omit <- output.cumulative.df %>%
dplyr::filter(!obs_volume %in% 'has no volume') #%>%
delta_abs_figure <- ggplot(
(output.cumulative.df_omit %>% dplyr::filter(!(Type == 'Sample' & Count == 0))),
aes(hours, delta_florescence, group = Well)) +
# geom_point(aes(color = Type)) +
geom_smooth(aes(color = Type), method = "lm", se = FALSE) +
facet_wrap(~Treatment,scales = "free")
delta_abs_figure
delta_abs_figure
AUC_cor_by_count <- ggplot(output.cor.df_final_omit,
aes(x = Count, y = AUC_cor,  color = Family_EBV)) +
geom_point(fill = "steelblue")+
facet_wrap(~Treatment,scales = "free")
AUC_cor_by_count <- ggplot(output.cor.df_final_omit,
aes(x = Count, y = AUC_cor,  color = Family_EBV)) +
geom_point(fill = "steelblue")+
facet_wrap(~Treatment,scales = "free")
AUC_cor_by_count
summary.df <- Rmisc::summarySE(
data = (output.cor.df),
groupvars = c('Family', 'Treatment'),
measurevar = 'AUC_cor_norm')
summary.df <- summary.df %>% dplyr::mutate(Family_EBV =
dplyr::case_when(Family > 50 ~ 'Low',
Family < 20 ~ 'High'))
AUC_cor_by_count_fam <- ggplot(summary.df,
aes(x = as.factor(as.numeric(Family)), y = AUC_cor_norm, color = Family_EBV)) +
geom_point(fill = "steelblue") +
geom_errorbar(aes(ymin = AUC_cor_norm - se, ymax = AUC_cor_norm + se), width = 0.2) +
theme_classic() +
facet_wrap(~Treatment,scales = "free")
AUC_cor_by_count_fam <- ggplot(summary.df,
aes(x = Treatment, y = AUC_cor_norm, group = as.factor(as.numeric(Family)), color = Family_EBV)) +
geom_point(fill = "steelblue") +
geom_smooth(method = "loess", se = TRUE) +
# geom_errorbar(aes(ymin = AUC_cor_norm - se, ymax = AUC_cor_norm + se), width = 0.2) +
theme_classic() +
facet_wrap(~Family_EBV)
AUC_cor_by_count_fam2 <- ggplot(summary.df,
aes(x = Treatment, y = AUC_cor_norm, group = Family_EBV, color = Family_EBV)) +
geom_point(fill = "steelblue") +
geom_smooth(method = "loess",               # Apply LOESS smoothing
se = TRUE,                      # Show 95% CI (grey ribbon)
level = 0.95,
span = 0.8)  +
theme_classic() +
facet_wrap(~Family_EBV)
# ?facet_wrap
ggarrange(delta_abs_figure,
AUC_cor_by_count,
AUC_cor_by_count_fam,
AUC_cor_by_count_fam2,
nrow=2,
ncol=2)
