# ---- read raw file ----
raw <- readLines("C:/Users/gurrs/Documents/6_Github_repositories/GurrLab/Yaquina_Heartbeat/Data/Olucida/20260323_050008.CSV")
raw
# Keep only lines that begin with a timestamp and contain 10 sensor values
pat <- "^\\d{4}-\\d{2}-\\d{2}\\s+\\d{6}\\.\\d{3}(\\d{10})$"
lines <- raw[str_detect(raw, pat)]
lines
raw
parse_line <- function(x) {
ts <- str_extract(x, "^\\d{4}-\\d{2}-\\d{2}\\s+\\d{6}\\.\\d{3}")
vals <- str_match(x, pat)[, 2]
sensors <- as.integer(str_split(vals, "", simplify = TRUE))
tibble(
time = as.POSIXct(ts, format = "%Y-%m-%d %H%M%S.%OS", tz = "UTC"),
Sensor1 = sensors[1],
Sensor2 = sensors[2],
Sensor3 = sensors[3],
Sensor4 = sensors[4],
Sensor5 = sensors[5],
Sensor6 = sensors[6],
Sensor7 = sensors[7],
Sensor8 = sensors[8],
Sensor9 = sensors[9],
Sensor10 = sensors[10]
)
}
df <- map_dfr(lines, parse_line) |>
mutate(t_sec = as.numeric(difftime(time, first(time), units = "secs")))
