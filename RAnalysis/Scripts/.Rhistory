grepl("38C", plate, ignore.case = TRUE) ~ "38C"),
PlateID = dplyr::case_when(
grepl("26C", plate, ignore.case = TRUE) ~ "plate_1_26",
grepl("30C", plate, ignore.case = TRUE) ~ "plate_2_30",
grepl("34C", plate, ignore.case = TRUE) ~"plate_3_34",
