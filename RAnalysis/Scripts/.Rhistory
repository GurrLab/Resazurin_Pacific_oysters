output.df <- data.frame()
loop.df_m   <- data.frame(unique(rbind.df$PlateID))
loop.df_i   <- data.frame(unique(rbind.df$Well))
# Call the cumulative dataframe that we will write to in the for loop below
output.cumulative.df <- data.frame() # start dataframe
output.df            <- data.frame() # start dataframe
output.cor.df        <- data.frame() # start dataframe
running.df           <- data.frame(matrix(nrow = 1, ncol = 9)) # create dataframe to save cumunalitively during for loop
colnames(running.df) <- c('Date', 'Treatment', 'PlateID', 'Age', 'Well', 'Family', 'Type', 'Count', 'AUC') # names for columns in the for loop
output.df <- data.frame()
output.df <- data.frame()
loop.df_m   <- data.frame(unique(rbind.df_48dpf$PlateID))  # call specific df
loop.df_i   <- data.frame(unique(rbind.df_48dpf$Well))  # call specific df
# Call the cumulative dataframe that we will write to in the for loop below
output.cumulative.df <- data.frame() # start dataframe
output.df            <- data.frame() # start dataframe
output.cor.df        <- data.frame() # start dataframe
running.df           <- data.frame(matrix(nrow = 1, ncol = 9)) # create dataframe to save cumunalitively during for loop
colnames(running.df) <- c('Date', 'Treatment', 'PlateID', 'Age', 'Well', 'Family', 'Type', 'Count', 'AUC') # names for columns in the for loop
for(m in 1:nrow(loop.df_m)){
plate_id      <- data_merged_48dpf %>%   # call specific df
dplyr::filter(PlateID %in% loop.df_m[m,1])
for(i in 1:nrow(loop.df_i)){
well.over.time       <- plate_id %>%
dplyr::filter(Well %in% loop.df_i[i,1]) %>%
dplyr::arrange(time) %>%
dplyr::mutate(hours = as.numeric(difftime(time,
time[1],
units = "hours")),
delta_florescence = flourescence - flourescence[1],
AUC = pracma::trapz(
hours,
flourescence)) %>%
dplyr::select('Date', 'Treatment', 'PlateID', 'Age', 'time', 'Family', 'hours',
'Well', 'Type', 'Count', 'AUC', 'delta_florescence')
output.cumulative.df <- rbind(output.cumulative.df, well.over.time)
running.df$Date      <- well.over.time$Date[1]
running.df$Treatment <- well.over.time$Treatment[1]
running.df$PlateID   <- well.over.time$PlateID[1]
running.df$Age       <- well.over.time$Age[1]
running.df$Well      <- well.over.time$Well[1]
running.df$Family    <- well.over.time$Family[1]
running.df$Type      <- well.over.time$Type[1]
running.df$Count     <- well.over.time$Count[1]
running.df$AUC       <- well.over.time$AUC[1]
output.df <- rbind(output.df,
running.df) #bind to a cumulative list dataframe
print(output.df) # print to monitor progress
mean.AUC.blanks <- mean(
(output.df %>% dplyr::filter(Type %in% 'Blank'))$AUC
)
output.cor.df <- output.df %>%
dplyr::filter(!Type %in% 'Blank') %>%
dplyr::mutate(AUC_cor      = as.numeric(AUC-mean.AUC.blanks),
# AUC_cor_norm = AUC_cor/Count)
AUC_cor_norm = dplyr::case_when(
(AUC_cor < 0 | Count == 0) ~ NA,
(AUC_cor > 0 & Count > 0) ~ AUC_cor/Count)) %>%
na.omit()
}
}
output.cor.df
