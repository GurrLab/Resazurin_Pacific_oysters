for (i in 1:length(xlsx_list_48dpf)) {
x         <- (basename(xlsx_list_48dpf[i]))
x.2       <- sub("\\.xlsx$", "", noquote(x))
loop.df   <- covert_to_df_2(xlsx_list_48dpf[[x.2]])
rbind.df <- rbind(rbind.df,
loop.df) #bind to a cumulative list dataframe
print(rbind.df) # print to monitor progress
}
