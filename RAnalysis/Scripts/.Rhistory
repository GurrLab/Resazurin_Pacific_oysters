# ---- choose best channel ----
score_channel <- function(y) {
y <- as.numeric(y)
n <- length(y)
if (n < 200) return(-Inf)
win <- min(401, n - (1 - n %% 2))
if (win < 11) win <- 11
if (win %% 2 == 0) win <- win + 1
trend <- stats::predict(stats::loess(y ~ seq_along(y), span = 0.08))
resid <- y - trend
sm <- stats::filter(resid, rep(1/5, 5), sides = 2)
sm[is.na(sm)] <- 0
spec <- Mod(fft(sm - mean(sm)))
max(spec[-1]) / median(spec[-1])
}
sensor_cols <- paste0("Sensor", 1:10)
scores <- map_dbl(df[sensor_cols], score_channel)
