running.df$Well      <- well.over.time$Well[1]
running.df$Family    <- well.over.time$Family[1]
running.df$Type      <- well.over.time$Type[1]
running.df$Count     <- well.over.time$Count[1]
running.df$AUC       <- well.over.time$AUC[1]
output.df <- rbind(output.df,
running.df) #bind to a cumulative list dataframe
print(output.df) # print to monitor progress
mean.AUC.blanks <- mean(
(output.df %>% dplyr::filter(Type %in% 'Blank'))$AUC
)
output.cor.df <- output.df %>%
dplyr::filter(!Type %in% 'Blank') %>%
dplyr::mutate(AUC_cor      = as.numeric(AUC-mean.AUC.blanks),
# AUC_cor_norm = AUC_cor/Count)
AUC_cor_norm = dplyr::case_when(
(AUC_cor < 0 | Count == 0) ~ NA,
(AUC_cor > 0 & Count > 0) ~ AUC_cor/Count)) %>%
na.omit()
}
}
output.cor.df
